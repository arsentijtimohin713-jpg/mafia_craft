        .nick-input{display:flex;gap:10px}
        .nick-input input{padding:10px 15px;border-radius:30px;border:none;background:#2a2a3a;color:#fff}
        .load-btn{background:#ffd700;border:none;padding:10px 20px;border-radius:30px;cursor:pointer}
        .categories{display:flex;justify-content:center;gap:15px;margin-bottom:30px;flex-wrap:wrap}
        .cat-btn{background:rgba(0,0,0,.5);border:2px solid rgba(255,215,0,.3);padding:10px 25px;border-radius:50px;cursor:pointer;transition:.3s}
        .cat-btn.active{background:linear-gradient(135deg,#ffd700,#ff8c00);color:#1a1a2e;border-color:transparent}
        .products{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px}
        .card{background:rgba(0,0,0,.7);border-radius:20px;padding:20px;text-align:center;transition:.3s;border:1px solid rgba(255,215,0,.2)}
        .card:hover{transform:translateY(-5px);border-color:#ffd700}
        .card h3{font-size:1.3rem;margin:10px 0}
        .price{font-size:1.5rem;color:#ffd700;margin:10px 0}
        .stars{font-size:0.9rem;color:#aaa}
        .features{list-style:none;margin:15px 0;text-align:left}
        .features li{padding:5px 0;display:flex;align-items:center;gap:8px}
        .features li i{color:#4caf50}
        .buy-btn{background:#0088cc;border:none;padding:10px;border-radius:30px;color:#fff;cursor:pointer;width:100%;font-weight:bold;transition:.3s}
        .buy-btn:hover{background:#26a5e4}
        .modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.9);justify-content:center;align-items:center;z-index:1000}
        .modal-content{background:#1a1a2a;border-radius:20px;padding:25px;max-width:400px;width:90%;text-align:center;border:1px solid #ffd700}
        .close{float:right;font-size:28px;cursor:pointer}
        .telegram-btn{background:#26a5e4;border:none;padding:12px;border-radius:50px;color:#fff;font-size:1.1rem;cursor:pointer;width:100%;margin-top:15px}
        .notification{position:fixed;bottom:20px;right:20px;background:#4caf50;padding:12px 20px;border-radius:10px;transform:translateX(400px);transition:.3s;z-index:1000}
        .notification.show{transform:translateX(0)}
        footer{margin-top:40px;text-align:center;padding:20px;border-top:1px solid rgba(255,215,0,.2);color:#888}
        max-width:600px{.balance-card{flex-direction:column;text-align:center}.nick-input{justify-content:center}}
        .hidden{display:none}
    </style>
</head>
