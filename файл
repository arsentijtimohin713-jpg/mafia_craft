function showMsg(t,s='success'){let n=document.getElementById('notify');n.textContent=t;n.style.background=s==='success'?'#4caf50':'#f44336';n.classList.add('show');setTimeout(()=>n.classList.remove('show'),3000)}
function showTab(tab){document.querySelectorAll('.products').forEach(el=>el.classList.add('hidden'));document.getElementById(tab).classList.remove('hidden');document.querySelectorAll('.cat-btn').forEach(btn=>btn.classList.remove('active'));event.target.classList.add('active')}
function loadData(){let nick=document.getElementById('nick').value.trim();if(!nick)return showMsg('❌ Введи ник','error');localStorage.setItem('last_nick',nick);document.getElementById('coins').innerText=Math.floor(Math.random()*10000);showMsg(`✅ Данные ${nick} загружены`)}
