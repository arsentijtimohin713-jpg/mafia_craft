function payNow(){if(!currentBuy)return;purchases.push({...currentBuy,date:new Date().toISOString()});localStorage.setItem('purchases',JSON.stringify(purchases));window.open(`https://t.me/${BOT}?start=${currentBuy.id}`,'_blank');showMsg('✅ Перейди в Telegram для оплаты');closeModal()}
